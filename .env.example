# Docker Compose environment variables
# Copy to .env and fill in real values

# PostgreSQL (used by pgsql service)
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=

# MediaMTX credentials (used by mediamtx + nginx services)
MEDIAMTX_USER=admin
MEDIAMTX_PASSWORD=
MEDIAMTX_VIEWER_USER=viewer
MEDIAMTX_VIEWER_PASSWORD=
MEDIAMTX_VIEWER_AUTH=       # base64 of "VIEWER_USER:VIEWER_PASSWORD"
